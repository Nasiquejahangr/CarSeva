<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background: #0f172a;
        color: #e2e8f0;
        margin: 0;
        padding: 20px;
      }
      .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1200px;
        margin: 0 auto 40px;
      }
      .header h2 {
        margin: 0;
      }
      .user-info {
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #dc2626;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 18px;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
      }
      .nav-tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        border-bottom: 1px solid #334155;
        padding-bottom: 10px;
      }
      .nav-tabs a {
        padding: 10px 16px;
        text-decoration: none;
        color: #cbd5e1;
        border-bottom: 3px solid transparent;
        cursor: pointer;
      }
      .nav-tabs a.active {
        color: #22d3ee;
        border-bottom-color: #22d3ee;
      }
      .tab-content {
        display: none;
      }
      .tab-content.active {
        display: block;
      }
      .form-group {
        margin-bottom: 16px;
      }
      input,
      textarea {
        width: 100%;
        padding: 12px;
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 8px;
        color: #fff;
        font-family: Arial, sans-serif;
      }
      textarea {
        resize: vertical;
        min-height: 100px;
      }
      button {
        padding: 12px 24px;
        background: #22d3ee;
        color: #0f172a;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        cursor: pointer;
      }
      button:hover {
        background: #67e8f9;
      }
      .logout-btn {
        background: #f87171;
        color: #fff;
      }
      .logout-btn:hover {
        background: #ef4444;
      }
      .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
      }
      .service-card {
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 8px;
        overflow: hidden;
      }
      .service-card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
      }
      .service-card-body {
        padding: 16px;
      }
      .service-card-body h3 {
        margin: 0 0 8px;
        color: #22d3ee;
      }
      .service-card-body p {
        margin: 0 0 12px;
        color: #cbd5e1;
        font-size: 14px;
      }
      .delete-btn {
        background: #f87171;
        padding: 8px 16px;
        font-size: 14px;
      }
      .delete-btn:hover {
        background: #ef4444;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h2>Admin Dashboard</h2>
      <div class="user-info">
        <div class="avatar">
          <%= (admin.name || "A").charAt(0).toUpperCase() %>
        </div>
        <div>
          <p style="margin: 0; font-weight: 700"><%= admin.name %></p>
          <p style="margin: 0; font-size: 14px; color: #94a3b8">
            <%= admin.email %>
          </p>
        </div>
        <form action="/admin/logout" method="POST" style="margin: 0">
          <button type="submit" class="logout-btn">Logout</button>
        </form>
      </div>
    </div>

    <div class="container">
      <div class="nav-tabs">
        <a href="#" class="tab-link active" data-tab="add-service"
          >Add Service</a
        >
        <a href="#" class="tab-link" data-tab="all-services">All Services</a>
        <a
          href="/admin/bookings"
          style="
            padding: 10px 16px;
            text-decoration: none;
            color: #cbd5e1;
            border-bottom: 3px solid transparent;
          "
          >Bookings</a
        >
      </div>

      <!-- Add Service Tab -->
      <div id="add-service" class="tab-content active">
        <h3>Add New Service</h3>
        <form id="add-service-form" style="max-width: 500px">
          <div class="form-group">
            <label for="service-name">Service Name</label>
            <input
              type="text"
              id="service-name"
              placeholder="e.g., Oil Change"
              required
            />
          </div>
          <div class="form-group">
            <label for="service-description">Description</label>
            <textarea
              id="service-description"
              placeholder="Describe the service..."
              required
            ></textarea>
          </div>
          <div class="form-group">
            <label for="service-image">Image URL</label>
            <input
              type="url"
              id="service-image"
              placeholder="https://example.com/image.jpg"
              required
            />
          </div>
          <button type="submit">Add Service</button>
          <p id="add-message" style="margin-top: 10px; display: none"></p>
        </form>
      </div>

      <!-- All Services Tab -->
      <div id="all-services" class="tab-content">
        <h3>All Services</h3>
        <div class="services-grid" id="services-container">
          <p>Loading services...</p>
        </div>
      </div>
    </div>

    <script>
      // Tab switching
      document.querySelectorAll(".tab-link").forEach((link) => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const tabName = link.getAttribute("data-tab");

          document
            .querySelectorAll(".tab-link")
            .forEach((l) => l.classList.remove("active"));
          document
            .querySelectorAll(".tab-content")
            .forEach((t) => t.classList.remove("active"));

          link.classList.add("active");
          document.getElementById(tabName).classList.add("active");

          if (tabName === "all-services") {
            loadServices();
          }
        });
      });

      // Add Service Form
      document
        .getElementById("add-service-form")
        .addEventListener("submit", async (e) => {
          e.preventDefault();

          const name = document.getElementById("service-name").value;
          const description = document.getElementById(
            "service-description",
          ).value;
          const image = document.getElementById("service-image").value;
          const messageEl = document.getElementById("add-message");

          try {
            const res = await fetch("/admin/services", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ name, description, image }),
            });

            const data = await res.json();
            if (res.ok) {
              messageEl.style.color = "#22d3ee";
              messageEl.textContent = "✓ Service added successfully!";
              document.getElementById("add-service-form").reset();
              setTimeout(() => {
                messageEl.style.display = "none";
              }, 3000);
            } else {
              messageEl.style.color = "#f87171";
              messageEl.textContent = "✗ " + data.error;
            }
            messageEl.style.display = "block";
          } catch (error) {
            messageEl.style.color = "#f87171";
            messageEl.textContent = "✗ Something went wrong";
            messageEl.style.display = "block";
          }
        });

      // Load Services
      async function loadServices() {
        try {
          const res = await fetch("/admin/services");
          const text = await res.text();
          // Parse HTML response to extract services data
          const container = document.getElementById("services-container");
          container.innerHTML = "<p>Loading...</p>";

          // Fetch via API endpoint instead
          const adminRes = await fetch("/api/admin/services");
          if (adminRes.ok) {
            const services = await adminRes.json();
            displayServices(services);
          }
        } catch (error) {
          document.getElementById("services-container").innerHTML =
            "<p>Failed to load services</p>";
        }
      }

      function displayServices(services) {
        const container = document.getElementById("services-container");
        if (services.length === 0) {
          container.innerHTML = "<p>No services added yet</p>";
          return;
        }

        container.innerHTML = services
          .map(
            (service) => `
          <div class="service-card">
            <img src="${service.image}" alt="${service.name}" />
            <div class="service-card-body">
              <h3>${service.name}</h3>
              <p>${service.description}</p>
              <button class="delete-btn" onclick="deleteService('${service._id}')">Delete</button>
            </div>
          </div>
        `,
          )
          .join("");
      }

      async function deleteService(id) {
        if (!confirm("Are you sure you want to delete this service?")) return;

        try {
          const res = await fetch(`/admin/services/${id}`, {
            method: "DELETE",
          });
          if (res.ok) {
            loadServices();
          }
        } catch (error) {
          alert("Failed to delete service");
        }
      }
    </script>
  </body>
</html>
