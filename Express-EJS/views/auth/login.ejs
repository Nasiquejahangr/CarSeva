<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Login</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include("../partials/navbar") %>

    <section>
      <div class="container" style="max-width: 460px; margin-top: 40px;">
        <h2>User Login</h2>
        <% if (error) { %>
        <p style="color: #f87171; margin: 10px 0;"><%= error %></p>
        <% } %>

        <form action="/login" method="POST" style="display: grid; gap: 12px; margin-top: 14px;">
          <input type="email" name="email" placeholder="Email" required style="padding: 12px; border-radius: 10px; border: 1px solid #334155;" />
          <input type="password" name="password" placeholder="Password" required style="padding: 12px; border-radius: 10px; border: 1px solid #334155;" />
          <button type="submit" class="btn btn-primary">Login</button>
        </form>

        <p style="margin-top: 14px;">No account? <a href="/signup" style="color: #22d3ee;">Sign up</a></p>
      </div>
    </section>
  </body>
</html>
